      { "name": "Edge",        "pipeline": "pipelines/TestEdgePipeline.json",    "enabled": true },
      { "name": "PhysicsDebug","pipeline": "pipelines/PhysicsDebugPipeline.json","enabled": false }
    ],
    "Transparent": [
      {
        "name": "Sparks",
        "pipeline": "pipelines/ParticlePipeline.json",
        "enabled": true
      }
    ],
    "Skybox": [
      { "name": "Skybox", "pipeline": "pipelines/SkyboxPipeline.json", "enabled": true }
    ],
    "Postprocess": []
  }
