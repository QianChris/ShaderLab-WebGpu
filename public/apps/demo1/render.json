      { "name": "Mesh",        "pipeline": "core:pipelines/TestMeshPipeline.json",    "enabled": true },
      { "name": "PbrSolid",    "pipeline": "core:pipelines/PbrPipeline.json",         "enabled": true },
      { "name": "Edge",        "pipeline": "core:pipelines/TestEdgePipeline.json",    "enabled": true },
      { "name": "Point",       "pipeline": "core:pipelines/TestPointPipeline.json",   "enabled": true },
      { "name": "PhysicsDebug","pipeline": "physics:pipelines/PhysicsDebugPipeline.json","enabled": true }
    ],
    "Transparent": [
      {
        "name": "Particles",
        "pipeline": "particles:pipelines/ParticlePipeline.json",
        "enabled": true
      }
