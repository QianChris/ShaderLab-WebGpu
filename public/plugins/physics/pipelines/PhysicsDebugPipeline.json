{
  "name": "PhysicsDebugPipeline",
  "vertex": { "shader": "../shaders/PhysicsDebug.wgsl", "entryPoint": "vs" },
  "fragment": { "shader": "../shaders/PhysicsDebug.wgsl", "entryPoint": "fs" },
  "primitive": { "topology": "line-list", "cullMode": "none" },
  "vertexLayouts": [
    {
      "arrayStride": 12, "stepMode": "vertex",
      "attributes": [{ "format": "float32x3", "offset": 0, "shaderLocation": 0 }]
    },
    {
      "arrayStride": 16, "stepMode": "vertex",
      "attributes": [{ "format": "float32x4", "offset": 0, "shaderLocation": 1 }]
    }
  ],
  "depthStencil": { "format": "depth24plus", "depthWriteEnabled": true, "depthCompare": "less-equal" },
  "bindLayout": ["frame"],
  "renderer": {
    "phase": "Opaque",
    "target": { "color": "scene", "depth": "sceneDepth" },
    "geometry": { "hook": "physics.debug" }
  }
}
